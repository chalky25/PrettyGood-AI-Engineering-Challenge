# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=          # E.164, e.g. +15551234567

# Target (Pretty Good AI test line — do not change for the challenge)
TARGET_PHONE_NUMBER=+18054398008

# Public HTTPS URL for Twilio webhooks (ngrok or similar)
PUBLIC_URL=

# Deepgram (STT + TTS)
DEEPGRAM_API_KEY=

# Groq (patient simulator + post-call analysis)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Optional tuning
DEEPGRAM_STT_MODEL=nova-2
DEEPGRAM_STT_MODEL_ES=nova-2
DEEPGRAM_TTS_VOICE=aura-asteria-en
DEEPGRAM_TTS_VOICE_ES=aura-2-celeste-es
ENDPOINTING_MS=900
MAX_REPLY_WORDS=25

# Server
HOST=0.0.0.0
PORT=8000
ARTIFACTS_DIR=artifacts
